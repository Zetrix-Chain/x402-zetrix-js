# ============================================================
# Resource Server — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# Port the server listens on
PORT=3000

# ---- Payment recipient ----
# Zetrix wallet address that receives payments
X402_ADDRESS=Z...

# ---- Network ----
# Valid values: zetrix:mainnet | zetrix:testnet
X402_NETWORK=zetrix:testnet

# ---- Payment amount ----
# Amount in smallest unit (e.g. 10000 = 0.01 ZTX at 6 decimals)
X402_PAYMENT_AMOUNT=10000

# ---- Facilitator — private server-side credentials ----
# These are never sent to clients. The resource server uses them to call
# /verify, /settle, and /settle/status on the Facilitator API.
X402_FACILITATOR_URL=https://facilitator.internal/api/v1/facilitator
X402_FACILITATOR_API_KEY=your-api-key-here
X402_FACILITATOR_BEARER_TOKEN=your-bearer-token-here

# ---- Prepare endpoint — public proxy URL ----
# This URL is advertised to clients in the 402 response so they can call
# /prepare without needing auth. Only required for gasModel:facilitator.
# For gasModel:client (ZTX self-pay) this can be left empty.
X402_PREPARE_ENDPOINT=
