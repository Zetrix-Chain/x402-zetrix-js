# ============================================================
# AI Agent Example — Environment Variables
# Copy this file to .env and fill in the values.
# ============================================================

# ---- Anthropic API ----
ANTHROPIC_API_KEY=sk-ant-...
# Override the Claude model used by the agent (default: claude-opus-4-8)
ANTHROPIC_MODEL=

# ---- Zetrix wallet (pays for API access) ----
X402_PRIVATE_KEY=your-ed25519-private-key
X402_ADDRESS=Z...
X402_NETWORK=zetrix:testnet

# ---- Zetrix RPC node ----
# Leave empty to use the default DNS-mapped node for the selected network.
# Set to a specific IP if connecting directly to a node:
#   mainnet node port: 18002
#   testnet node port: 19333
X402_NODE_HOST=
X402_NODE_PORT=

# ---- Payment policy (optional) ----
# Maximum amount the agent is allowed to pay per request (in smallest unit).
# Leave empty for no limit.
X402_MAX_AMOUNT_PER_REQUEST=

# ---- Facilitator (required by the resource server you connect to) ----
# Not used by the agent itself, but useful when running resource-server locally.
X402_FACILITATOR_URL=
X402_FACILITATOR_API_KEY=
X402_FACILITATOR_BEARER_TOKEN=

# ---- Target resource server ----
# URL of the x402-protected API the agent will access.
# Run examples/resource-server to start a local one.
RESOURCE_URL=http://localhost:3000/api/data

# ---- Agent prompt (optional override) ----
# Default prompt if not passed via command line.
AGENT_PROMPT=
